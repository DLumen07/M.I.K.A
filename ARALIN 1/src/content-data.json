      "questions": [
        {
          "index": 0,
          "question": "<p><strong>Ito ay nangangahulugang walang laman; walang saysay o kabuluhan.</strong></p>",
          "correctAnswerIndex": 0,
          "answers": [
            "<p>hungkag</p>",
            "<p>walang pakinabang</p>",
            "<p>walang gamit</p>"
          ]
        },
        {
          "index": 1,
          "question": "<p><strong>Ito ay nangangahulugang pagmamahal o pagkagusto sa isang tao o bagay; pagkahumaling.</strong></p>",
          "correctAnswerIndex": 0,
          "answers": [
            "<p>pagliyag</p>",
            "<p>pangarap</p>",
            "<p>pagnanasa</p>"
          ]
        },
        {
          "index": 2,
          "question": "<p><strong>Ito ay nangangahulugang makinis at malambot tulad ng sutla.</strong></p>",
          "correctAnswerIndex": 0,
          "answers": [
            "<p>malasutla</p>",
            "<p>malambot</p>",
            "<p>kahalihalina</p>"
          ]
        },
        {
          "index": 3,
          "question": "<p><strong>Ito ay nangangahulugang nakararamdam ng takot o pag-aalala; nababahala.</strong></p>",
          "correctAnswerIndex": 0,
          "answers": [
            "<p>nangangamba</p>",
            "<p>nangingilabot</p>",
            "<p>nagdaramdam</p>"
          ]
        },
        {
          "index": 4,
          "question": "<p><strong>Ito ay nangangahulugang malungkot, malamlam, o walang kasiyahan ang damdamin o kapaligiran.</strong></p>",
          "correctAnswerIndex": 0,
          "answers": [
            "<p>mapanglaw</p>",
            "<p>masalimuot</p>",
            "<p>nagdurusa</p>"
          ]
        }
      ]
    },
